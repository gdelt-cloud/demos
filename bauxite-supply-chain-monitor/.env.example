# GDELT Cloud API key. Get one at https://gdeltcloud.com/api-keys
GDELT_API_KEY=gdelt_sk_your_key_here

# Base URL — leave as default for prod; set to http://localhost:3000 for local dev
GDELT_BASE_URL=https://gdeltcloud.com

# Optional — pin a fixed date window. Defaults to last 30 days if unset.
# BAUXITE_DATE_START=2026-04-21
# BAUXITE_DATE_END=2026-05-21
