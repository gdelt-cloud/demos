<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Bauxite Supply-Chain Monitor · GDELT Cloud</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
  <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
  <style>
    body { font-family: -apple-system, BlinkMacSystemFont, "Inter", "SF Pro", Helvetica, Arial, sans-serif; background-color: #f8fafc; color: #0f172a; }
    .font-display { font-family: "Inter", -apple-system, sans-serif; letter-spacing: 0.02em; }
    .neon { color: #2e8de0; }
    .neon-border { border-color: rgba(46, 141, 224, 0.20); }
    #map { height: 360px; width: 100%; border-radius: 0.5rem; }
    .tl-axis { background: linear-gradient(90deg, rgba(46,141,224,0.20), rgba(46,141,224,0.55), rgba(31,148,102,0.35)); }
    .tl-dot { transition: transform 120ms ease; }
    .tl-dot:hover { transform: scale(1.15); }
    .tl-tooltip { position: absolute; width: 240px; pointer-events: none; z-index: 20; background: rgba(255, 255, 255, 0.97); box-shadow: 0 12px 32px -12px rgba(0,0,0,0.22); border-radius: 0.5rem; padding: 0.55rem 0.7rem; visibility: hidden; }
    .tl-link:hover .tl-tooltip { visibility: visible; }
    .card-link { transition: background-color 120ms ease, border-color 120ms ease; }
    .card-link:hover { background-color: rgba(46,141,224,0.05); }
    .goldstein-spectrum { background: linear-gradient(90deg, #dc2626 0%, #ea580c 25%, #f59e0b 50%, #84cc16 75%, #16a34a 100%); }
    .score-bar { background-color: rgba(15,23,42,0.08); height: 8px; border-radius: 999px; overflow: hidden; }
    .score-bar > div { height: 100%; border-radius: 999px; }
  </style>
</head>
<body>
  <main class="mx-auto max-w-7xl px-4 py-10 md:px-8">
    <header class="mb-6 border-b border-slate-200 pb-6">
      <div class="flex items-center gap-2 text-[11px] font-semibold uppercase tracking-[0.18em] neon">
        <span class="inline-block h-1.5 w-1.5 rounded-full bg-emerald-500"></span>
        Commodity Supply Chain · GDELT Cloud Demo
      </div>
      <h1 class="mt-2 text-3xl font-bold tracking-tight md:text-4xl">Bauxite Supply-Chain Monitor</h1>
      <p class="mt-2 max-w-3xl text-sm text-slate-600">
        Global aluminum smelters source ~75% of their bauxite from Guinea, Indonesia, and Australia. Weekly
        operating picture of the political-risk, infrastructure, and trade events shaping those three regions.
      </p>
      <div class="mt-3 text-xs text-slate-500">
        Window: <strong>{{ start_date }}</strong> → <strong>{{ end_date }}</strong>
      </div>
    </header>

    <!-- KPI tiles -->
    <section class="mb-8 grid grid-cols-2 gap-3 md:grid-cols-4">
      <div class="rounded-lg border neon-border bg-white p-4">
        <div class="text-[10px] uppercase tracking-[0.18em] text-slate-500">Events</div>
        <div class="mt-1 text-2xl font-bold">{{ total_events }}</div>
        <div class="text-[11px] text-slate-500">across {{ country_count }} regions</div>
      </div>
      <div class="rounded-lg border neon-border bg-white p-4">
        <div class="text-[10px] uppercase tracking-[0.18em] text-slate-500">Story clusters</div>
        <div class="mt-1 text-2xl font-bold">{{ total_stories }}</div>
        <div class="text-[11px] text-slate-500">commodity-tagged</div>
      </div>
      <div class="rounded-lg border neon-border bg-white p-4">
        <div class="text-[10px] uppercase tracking-[0.18em] text-slate-500">Fatal incidents</div>
        <div class="mt-1 text-2xl font-bold">{{ total_fatal }}</div>
        <div class="text-[11px] text-slate-500">aggregate</div>
      </div>
      <div class="rounded-lg border neon-border bg-white p-4">
        <div class="text-[10px] uppercase tracking-[0.18em] text-slate-500">Sourcing regions</div>
        <div class="mt-1 text-2xl font-bold">{{ country_count }}</div>
        <div class="text-[11px] text-slate-500">Guinea · Indonesia · Australia</div>
      </div>
    </section>

    <!-- Per-country panels with CAMEO+ score bars + Goldstein spectrum -->
    <section class="mb-8">
      <h2 class="mb-4 text-[11px] font-semibold uppercase tracking-[0.18em] text-slate-500">Three-country panel · sourcing risk</h2>
      <div class="grid gap-4 md:grid-cols-3">
        {% for p in panels %}
          <div class="rounded-lg border neon-border bg-white p-5">
            <div class="flex items-baseline justify-between">
              <div>
                <h3 class="text-lg font-bold tracking-tight uppercase">{{ p.label }}</h3>
                <div class="mt-0.5 text-[10px] uppercase tracking-wider text-slate-500">{{ p.iso3 }}</div>
              </div>
              <div class="text-right">
                <div class="font-mono text-2xl font-semibold">{{ p.event_count }}</div>
                <div class="text-[10px] uppercase tracking-wider text-slate-500">events / window</div>
              </div>
            </div>
            <div class="mt-1.5 text-[12px] text-slate-600">{{ p.subtitle }}</div>

            <!-- Goldstein severity spectrum bar -->
            <div class="mt-4">
              <div class="text-[9px] uppercase tracking-wider text-slate-500 font-semibold">
                Avg Goldstein
                <span class="ml-1 font-mono text-slate-700">{% if p.avg_goldstein is not none %}{{ "%.1f"|format(p.avg_goldstein) }}{% else %}—{% endif %}</span>
                <span class="ml-1 text-slate-500">· {{ p.spectrum_label }}</span>
              </div>
              <div class="relative mt-1 h-2 rounded-full goldstein-spectrum">
                <div class="absolute top-1/2 -translate-y-1/2 -translate-x-1/2 h-3 w-3 rounded-full border-2 border-white shadow"
                     style="left: {{ p.spectrum_pct }}%; background: #0f172a;"></div>
              </div>
              <div class="mt-0.5 flex justify-between text-[9px] uppercase tracking-wider text-slate-400">
                <span>-10 conflict</span><span>+10 cooperative</span>
              </div>
            </div>

            <!-- CAMEO+ score bars -->
            <div class="mt-4 space-y-2">
              <div class="text-[9px] uppercase tracking-wider text-slate-500 font-semibold">CAMEO+ event-quality scores · avg over window</div>
              {% set prop_pct = (p.avg_propagation * 100) if p.avg_propagation else 0 %}
              {% set mkt_pct = (p.avg_market_sensitivity * 100) if p.avg_market_sensitivity else 0 %}
              {% set sys_pct = (p.avg_systemic * 100) if p.avg_systemic else 0 %}
              <div>
                <div class="flex justify-between text-[10px] text-slate-500">
                  <span>Propagation</span><span class="font-mono">{{ "%d"|format(prop_pct|round) }}%</span>
                </div>
                <div class="score-bar mt-0.5"><div style="width: {{ [prop_pct, 2]|max }}%; background-color: {% if prop_pct >= 70 %}#dc2626{% elif prop_pct >= 50 %}#ea580c{% elif prop_pct >= 30 %}#f59e0b{% else %}#84cc16{% endif %};"></div></div>
              </div>
              <div>
                <div class="flex justify-between text-[10px] text-slate-500">
                  <span>Market sensitivity</span><span class="font-mono">{{ "%d"|format(mkt_pct|round) }}%</span>
                </div>
                <div class="score-bar mt-0.5"><div style="width: {{ [mkt_pct, 2]|max }}%; background-color: {% if mkt_pct >= 70 %}#dc2626{% elif mkt_pct >= 50 %}#ea580c{% elif mkt_pct >= 30 %}#f59e0b{% else %}#84cc16{% endif %};"></div></div>
              </div>
              <div>
                <div class="flex justify-between text-[10px] text-slate-500">
                  <span>Systemic importance</span><span class="font-mono">{{ "%d"|format(sys_pct|round) }}%</span>
                </div>
                <div class="score-bar mt-0.5"><div style="width: {{ [sys_pct, 2]|max }}%; background-color: {% if sys_pct >= 70 %}#dc2626{% elif sys_pct >= 50 %}#ea580c{% elif sys_pct >= 30 %}#f59e0b{% else %}#84cc16{% endif %};"></div></div>
              </div>
            </div>

            <!-- Mini stats -->
            <div class="mt-4 grid grid-cols-3 gap-2 text-[10px]">
              <div class="rounded border border-slate-200 bg-slate-50 p-2">
                <div class="uppercase tracking-wider text-slate-500">Articles</div>
                <div class="mt-0.5 font-mono text-slate-800">{{ p.article_count }}</div>
              </div>
              <div class="rounded border border-slate-200 bg-slate-50 p-2">
                <div class="uppercase tracking-wider text-slate-500">Avg mag</div>
                <div class="mt-0.5 font-mono text-slate-800">{% if p.avg_magnitude is not none %}{{ "%.1f"|format(p.avg_magnitude) }}{% else %}—{% endif %}</div>
              </div>
              <div class="rounded border border-slate-200 bg-slate-50 p-2">
                <div class="uppercase tracking-wider text-slate-500">Fatalities</div>
                <div class="mt-0.5 font-mono text-slate-800">{{ p.fatal_count }}</div>
              </div>
            </div>
            {% if p.top_actor %}
              <div class="mt-3 text-[10px] uppercase tracking-wider text-slate-500">
                Top actor · <span class="font-semibold text-slate-700 normal-case">{{ p.top_actor }}</span>
              </div>
            {% endif %}
          </div>
        {% endfor %}
      </div>
    </section>

    <!-- Horizontal event timeline -->
    <section class="mb-8">
      <div class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm">
        <div class="mb-3 flex items-baseline justify-between gap-3">
          <h3 class="text-[11px] font-semibold uppercase tracking-[0.18em] text-slate-500">
            Event timeline · Guinea + Indonesia + Australia
          </h3>
          <span class="font-mono text-[10px] text-slate-400">{{ start_date }} → {{ end_date }} · {{ timeline_events|length }} events</span>
        </div>
        <div class="relative" style="height: 150px;">
          <div class="tl-axis pointer-events-none absolute left-0 right-0" style="top: 75px; height: 1px;"></div>
          {% for m in day_markers %}
            <div class="pointer-events-none absolute" style="left: {{ m.pct }}%; top: 71px;">
              <div class="h-2 w-px bg-slate-300"></div>
              <div class="mt-1 -translate-x-1/2 text-[9px] uppercase tracking-[0.14em] text-slate-400">{{ m.label }}</div>
            </div>
          {% endfor %}
          {% for ev in timeline_events %}
            {% set top = 75 + ev.lane * 22 - ev.r %}
            <a class="tl-link" href="{{ ev.url or '#' }}" {% if ev.url %}target="_blank" rel="noopener noreferrer"{% endif %}>
              <span class="tl-dot absolute flex items-center justify-center rounded-full bg-white"
                    style="top: {{ top }}px; left: calc({{ ev.pct }}% - {{ ev.r }}px); width: {{ ev.r * 2 }}px; height: {{ ev.r * 2 }}px; border: 2px solid {{ ev.color }};">
                <svg width="{{ ev.icon_px }}" height="{{ ev.icon_px }}" viewBox="0 0 24 24" fill="none" stroke="{{ ev.color }}" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="{{ ev.icon_d }}"></path>
                </svg>
              </span>
              <span class="tl-tooltip"
                    style="left: {% if ev.pct < 18 %}{{ ev.pct }}%; transform: translateX(0){% elif ev.pct > 82 %}auto; right: {{ 100 - ev.pct }}%; transform: translateX(0){% else %}{{ ev.pct }}%; transform: translateX(-50%){% endif %};
                           {% if ev.lane > 0 %}top: {{ top + ev.r * 2 + 6 }}px;{% else %}top: {{ top - 80 }}px;{% endif %}
                           border: 1px solid {{ ev.color }};">
                <span class="text-[10px] uppercase tracking-wider font-semibold" style="color: {{ ev.color }};">
                  {{ ev.category or 'Event' }}{% if ev.subcategory %} · <span class="text-slate-500">{{ ev.subcategory }}</span>{% endif %}
                </span>
                <div class="mt-0.5 text-[12px] font-medium leading-snug text-slate-800 line-clamp-3">{{ ev.title or '—' }}</div>
                <div class="mt-1 font-mono text-[10px] text-slate-500">{{ ev.event_date }}{% if ev.country %} · {{ ev.country }}{% endif %}</div>
              </span>
            </a>
          {% endfor %}
        </div>
      </div>
    </section>

    <!-- Panoramic world map -->
    <section class="mb-8">
      <h2 class="mb-3 text-[11px] font-semibold uppercase tracking-[0.18em] text-slate-500">Geographic picture</h2>
      <div id="map"></div>
      <p class="mt-3 text-[12px] text-slate-500">
        <span class="font-semibold uppercase tracking-wider text-slate-600">Legend ·</span>
        <span class="inline-block h-2 w-2 rounded-full align-middle" style="background:#ef4444"></span>
        circles = events (size = magnitude, color = Goldstein severity) · click any marker for detail.
      </p>
    </section>

    <!-- LME aluminum sparkline -->
    {% if macro_series %}
    <section class="mb-8">
      <h2 class="mb-3 text-[11px] font-semibold uppercase tracking-[0.18em] text-slate-500">LME aluminum spot · 30-day trend</h2>
      <div class="rounded-lg border bg-emerald-50/40 p-4" style="border-color: rgba(31,148,102,0.22)">
        <div class="grid gap-4 md:grid-cols-2">
          {% for s in macro_series %}
            <div class="flex flex-col gap-1">
              <div class="flex items-baseline justify-between gap-2">
                <span class="text-[10px] uppercase tracking-[0.16em] text-slate-500 font-semibold">{{ s.label }}</span>
                <div class="flex items-baseline gap-2 font-mono">
                  <span class="text-[13px] text-slate-700">{{ "%.1f"|format(s.last) }} <span class="text-[10px] text-slate-400">{{ s.unit }}</span></span>
                  <span class="text-[10px]" style="color: {{ s.color }};">
                    {% if s.direction == 'up' %}▲{% elif s.direction == 'down' %}▼{% else %}·{% endif %}
                    {% if s.delta_pct >= 0 %}+{% endif %}{{ "%.1f"|format(s.delta_pct) }}%
                  </span>
                </div>
              </div>
              <svg viewBox="0 0 {{ s.width }} {{ s.height }}" height="{{ s.height }}" class="block w-full">
                <line x1="0" x2="{{ s.width }}" y1="{{ s.height - 0.5 }}" y2="{{ s.height - 0.5 }}" stroke="rgba(15,23,42,0.10)" stroke-width="1"/>
                <path d="{{ s.path_d }}" fill="none" stroke="{{ s.color }}" stroke-width="1.5" stroke-linecap="round"/>
              </svg>
              <div class="flex justify-between font-mono text-[9px] text-slate-400">
                <span>{{ s.first_date }}</span><span>{{ s.last_date }}</span>
              </div>
            </div>
          {% endfor %}
        </div>
        <p class="mt-2 text-[11px] text-slate-500">Source: Alpha Vantage via GDELT Cloud MCP macro_finance proxy.</p>
      </div>
    </section>
    {% endif %}

    <!-- "What changed this week" — 3-column per-country events -->
    <section class="mb-8">
      <h2 class="mb-3 flex items-center gap-2 text-[11px] font-semibold uppercase tracking-[0.18em] text-slate-500">
        <span class="inline-flex h-1.5 w-1.5 rounded-full bg-rose-500"></span>
        What changed this week · structured events by sourcing country
      </h2>
      <div class="grid gap-6 lg:grid-cols-3">
        {% for c in per_country_top_events %}
          <div class="rounded-lg border neon-border bg-white">
            <div class="flex items-baseline justify-between border-b border-slate-100 px-3 py-2">
              <div class="text-[11px] uppercase tracking-[0.15em] font-semibold text-slate-700">{{ c.label }}</div>
              <div class="font-mono text-[10px] uppercase tracking-wider text-slate-500">{{ c.event_count }} events</div>
            </div>
            <ul class="divide-y divide-slate-100">
              {% for ev in c.top_events %}
                <li>
                  <a class="card-link block p-3" href="{{ ev.url or '#' }}" {% if ev.url %}target="_blank" rel="noopener noreferrer"{% endif %} style="border-left: 2px solid {{ ev.category_color }};">
                    <div class="flex items-start gap-2">
                      <span class="mt-0.5 flex h-6 w-6 shrink-0 items-center justify-center rounded-md" style="background-color: {{ ev.category_color }}1f">
                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="{{ ev.category_color }}" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="{{ ev.category_icon_d }}"></path></svg>
                      </span>
                      <div class="min-w-0 flex-1">
                        <div class="flex flex-wrap items-baseline gap-1.5 text-[10px] text-slate-500">
                          <span class="font-semibold uppercase tracking-wider" style="color: {{ ev.category_color }};">{{ ev.category or '—' }}</span>
                          {% if ev.subcategory %}<span class="text-[10px] uppercase tracking-wider text-slate-600">{{ ev.subcategory }}</span>{% endif %}
                        </div>
                        <div class="mt-0.5 font-mono text-[10px] text-slate-500">{{ ev.event_date }}</div>
                        <div class="mt-1 text-[12px] leading-snug text-slate-800">{{ ev.title or '—' }}</div>
                      </div>
                    </div>
                  </a>
                </li>
              {% else %}
                <li class="p-6 text-center text-[11px] text-slate-500">No events this week.</li>
              {% endfor %}
            </ul>
          </div>
        {% endfor %}
      </div>
    </section>

    <!-- Cross-country top story clusters -->
    <section class="mb-10">
      <h2 class="mb-3 flex items-center gap-2 text-[11px] font-semibold uppercase tracking-[0.18em] text-slate-500">
        <span class="inline-flex h-1.5 w-1.5 rotate-45 bg-violet-500"></span>
        Top story clusters · article reach across all three countries
      </h2>
      <ul class="grid gap-3 md:grid-cols-3">
        {% for s in cross_stories %}
          <li>
            <a class="card-link group block overflow-hidden rounded-lg border bg-violet-50/30 hover:bg-violet-50/60" style="border-color: rgba(139,92,246,0.22)" href="{{ s.url or '#' }}" {% if s.url %}target="_blank" rel="noopener noreferrer"{% endif %}>
              <div class="flex gap-3 p-3">
                <div class="relative h-16 w-16 shrink-0 overflow-hidden rounded-md bg-violet-100">
                  {% if s.image_url %}<img src="{{ s.image_url }}" alt="" referrerpolicy="no-referrer" loading="lazy" class="h-full w-full object-cover">
                  {% else %}<div class="flex h-full w-full items-center justify-center text-violet-500"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 22h16a2 2 0 0 0 2-2V4a2 2 0 0 0-2-2H8a2 2 0 0 0-2 2v16a2 2 0 0 1-2 2Zm0 0a2 2 0 0 1-2-2v-9c0-1.1.9-2 2-2h2M18 14h-8M15 18h-5M10 6h8v4h-8V6Z"/></svg></div>{% endif %}
                </div>
                <div class="min-w-0 flex-1">
                  <div class="flex items-baseline justify-between gap-2 text-[10px] text-slate-500">
                    <div class="flex flex-wrap items-baseline gap-1.5">
                      <span class="rounded bg-violet-100 px-1.5 py-0.5 font-semibold uppercase tracking-wider text-violet-700">Story</span>
                      {% if s.cluster_date %}<span class="font-mono">{{ s.cluster_date }}</span>{% endif %}
                      {% if s.country %}<span class="uppercase tracking-wider">· {{ s.country }}</span>{% endif %}
                    </div>
                    <span class="font-mono text-slate-400">sig {{ "%.2f"|format(s.significance) }}</span>
                  </div>
                  <div class="mt-1 line-clamp-2 text-[13px] font-medium leading-snug text-slate-800">{{ s.label }}</div>
                  <div class="mt-1.5 flex flex-wrap items-center gap-1.5 text-[10px] font-mono">
                    <span class="rounded bg-slate-100 px-1.5 py-0.5 uppercase tracking-wider text-slate-600">{{ s.article_count }} articles</span>
                    {% if s.source_domain %}<span class="text-slate-400">via {{ s.source_domain }}</span>{% endif %}
                  </div>
                </div>
              </div>
            </a>
          </li>
        {% else %}
          <li class="col-span-3 text-[12px] text-slate-500">No story clusters in window.</li>
        {% endfor %}
      </ul>
    </section>

    <footer class="mt-10 border-t border-slate-200 pt-6 text-xs text-slate-500">
      Built only on the GDELT Cloud public REST API + a static LME aluminum macro snapshot.
      Source repo: <a class="text-sky-600 hover:underline" href="https://github.com/gdelt-cloud/demos" target="_blank" rel="noopener noreferrer">github.com/gdelt-cloud/demos</a>.
    </footer>
  </main>

  <script type="application/json" id="map-payload">{{ map_payload_json | safe }}</script>
  <script>
    const payload = JSON.parse(document.getElementById('map-payload').textContent);
    const map = L.map('map').setView([0, 80], 2);
    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
      attribution: '&copy; OpenStreetMap contributors',
      maxZoom: 12,
    }).addTo(map);
    for (const ev of payload.events) {
      if (ev.latitude == null || ev.longitude == null) continue;
      const marker = L.circleMarker([ev.latitude, ev.longitude], {
        radius: (ev.marker_size || 10) / 2.2,
        color: ev.marker_color, fillColor: ev.marker_color, fillOpacity: 0.65, weight: 1.5,
      });
      const title = (ev.title || '').replace(/</g, '&lt;');
      marker.bindPopup(`<strong>${title}</strong><br><span style="font-size:11px;color:#64748b">${ev.event_date || ''} · ${ev.country || ''}</span>`);
      marker.addTo(map);
    }
  </script>
</body>
</html>
