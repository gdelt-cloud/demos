<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Bauxite Supply-Chain Monitor · GDELT Cloud</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
  <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
  <style>
    body { font-family: -apple-system, BlinkMacSystemFont, "Inter", "SF Pro", Helvetica, Arial, sans-serif; }
    .font-display { font-family: "Inter", -apple-system, sans-serif; letter-spacing: 0.02em; }
    .neon { color: #5EAAFF; }
    .neon-bg { background-color: rgba(94, 170, 255, 0.08); }
    .neon-border { border-color: rgba(94, 170, 255, 0.22); }
    .emerald { color: #10b981; }
    .emerald-bg { background-color: rgba(16, 185, 129, 0.06); }
    .emerald-border { border-color: rgba(16, 185, 129, 0.22); }
    #map { height: 460px; width: 100%; border-radius: 0.5rem; }
    .line-clamp-2 { display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
    .line-clamp-3 { display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; }
    @media print {
      .no-print { display: none !important; }
      #map { height: 320px; }
    }
  </style>
</head>
<body class="bg-slate-50 text-slate-900">
  <main class="mx-auto max-w-6xl px-4 py-10 md:px-8">
    <header class="mb-8 border-b border-slate-200 pb-6">
      <div class="flex items-center gap-2 text-[11px] font-semibold uppercase tracking-[0.18em] neon">
        <span class="inline-block h-1.5 w-1.5 rounded-full bg-[#5EAAFF]"></span>
        Commodity Supply Chain · GDELT Cloud Demo
      </div>
      <h1 class="mt-2 text-3xl font-bold tracking-tight md:text-4xl">Bauxite Supply-Chain Monitor</h1>
      <p class="mt-2 max-w-3xl text-sm text-slate-600">
        Global aluminum smelters source 75% of their bauxite from Guinea, Indonesia, and Australia. This monitor
        follows the political-risk, infrastructure, and trade events shaping those three regions — sized for a
        conglomerate Group Risk team. Built only on the GDELT Cloud public REST API.
      </p>
      <div class="mt-3 text-xs text-slate-500">
        Window: <strong>{{ start_date }}</strong> → <strong>{{ end_date }}</strong>
      </div>
    </header>

    {# ---- LME Aluminum sparkline (static placeholder) ----------------- #}
    <section class="mb-8">
      <div class="rounded-lg border emerald-border emerald-bg p-4">
        <div class="flex items-center justify-between gap-4">
          <div>
            <div class="text-[10px] uppercase tracking-[0.18em] emerald">{{ lme_label }}</div>
            <div class="mt-1 font-mono text-2xl">
              {{ "%.0f"|format(sparkline.last) }} {{ lme_unit }}
              {% if sparkline.delta_pct >= 0 %}
                <span class="ml-2 text-sm emerald">+{{ "%.1f"|format(sparkline.delta_pct) }}%</span>
              {% else %}
                <span class="ml-2 text-sm text-rose-500">{{ "%.1f"|format(sparkline.delta_pct) }}%</span>
              {% endif %}
            </div>
            <div class="text-[11px] text-slate-500">over the last {{ sparkline.count }} data points · static placeholder</div>
          </div>
          <svg width="{{ sparkline.width }}" height="{{ sparkline.height }}" viewBox="0 0 {{ sparkline.width }} {{ sparkline.height }}">
            <path d="{{ sparkline.path }}" fill="none" stroke="#10b981" stroke-width="1.5" />
          </svg>
        </div>
      </div>
    </section>

    {# ---- Stat tiles ------------------------------------------------- #}
    <section class="mb-8 grid grid-cols-2 gap-3 md:grid-cols-4">
      <div class="rounded-lg border neon-border bg-white p-4">
        <div class="text-[10px] uppercase tracking-[0.18em] text-slate-500">Events</div>
        <div class="mt-1 text-2xl font-bold">{{ total_events }}</div>
        <div class="text-[11px] text-slate-500">across {{ country_count }} countries</div>
      </div>
      <div class="rounded-lg border neon-border bg-white p-4">
        <div class="text-[10px] uppercase tracking-[0.18em] text-slate-500">Commodity stories</div>
        <div class="mt-1 text-2xl font-bold">{{ total_stories }}</div>
        <div class="text-[11px] text-slate-500">search · aluminum bauxite mining</div>
      </div>
      <div class="rounded-lg border neon-border bg-white p-4">
        <div class="text-[10px] uppercase tracking-[0.18em] text-slate-500">Fatal incidents</div>
        <div class="mt-1 text-2xl font-bold">{{ total_fatal }}</div>
        <div class="text-[11px] text-slate-500">summed across panels</div>
      </div>
      <div class="rounded-lg border neon-border bg-white p-4">
        <div class="text-[10px] uppercase tracking-[0.18em] text-slate-500">Sourcing regions</div>
        <div class="mt-1 text-2xl font-bold">{{ country_count }}</div>
        <div class="text-[11px] text-slate-500">Guinea · Indonesia · Australia</div>
      </div>
    </section>

    {# ---- Three-country panel grid ----------------------------------- #}
    <section class="mb-10">
      <h2 class="mb-3 text-[11px] font-semibold uppercase tracking-[0.18em] text-slate-500">
        Three-country panel · sourcing risk
      </h2>
      <div class="grid gap-4 md:grid-cols-3">
        {% for panel in panels %}
          <div class="rounded-lg border neon-border bg-white p-5">
            <div class="flex items-baseline justify-between">
              <div>
                <h3 class="text-lg font-semibold uppercase tracking-tight">{{ panel.label }}</h3>
                <div class="mt-0.5 text-[11px] uppercase tracking-wider text-slate-500">{{ panel.iso3 }}</div>
              </div>
              <div class="text-right">
                <div class="font-mono text-2xl text-slate-800">{{ panel.event_count }}</div>
                <div class="text-[11px] text-slate-500">events / 30d</div>
              </div>
            </div>
            <div class="mt-2 text-[12px] text-slate-600">{{ panel.subtitle }}</div>

            <div class="mt-4 grid grid-cols-3 gap-2 text-[11px]">
              <div class="rounded-md border border-slate-200 bg-slate-50 p-2">
                <div class="uppercase tracking-wider text-slate-500">Stories</div>
                <div class="mt-0.5 font-mono text-slate-800">{{ panel.story_count }}</div>
              </div>
              <div class="rounded-md border border-slate-200 bg-slate-50 p-2">
                <div class="uppercase tracking-wider text-slate-500">Fatal</div>
                <div class="mt-0.5 font-mono text-slate-800">{{ panel.fatal_count }}</div>
              </div>
              <div class="rounded-md border border-slate-200 bg-slate-50 p-2">
                <div class="uppercase tracking-wider text-slate-500">Top sig</div>
                <div class="mt-0.5 font-mono text-slate-800">{{ "%.2f"|format(panel.top_sig) }}</div>
              </div>
            </div>

            {% if panel.top_event %}
              <div class="mt-4">
                <div class="text-[11px] uppercase tracking-wider text-slate-500">Top event</div>
                <div class="mt-1 line-clamp-3 text-[13px] text-slate-800">{{ panel.top_event.title or "—" }}</div>
                <div class="mt-1 text-[11px] text-slate-400">
                  {{ panel.top_event.event_date }} · {{ panel.top_event.event_family }} · {{ panel.top_event.category }}
                </div>
              </div>
            {% endif %}
            {% if panel.top_story %}
              <div class="mt-3 border-t border-slate-100 pt-3">
                <div class="text-[11px] uppercase tracking-wider text-slate-500">Top commodity story</div>
                <div class="mt-1 line-clamp-2 text-[13px] text-slate-800">{{ panel.top_story.label }}</div>
                <div class="mt-1 text-[11px] text-slate-400">
                  {{ panel.top_story.cluster_date }} · {{ panel.top_story.article_count }} articles
                </div>
              </div>
            {% endif %}
          </div>
        {% endfor %}
      </div>
    </section>

    {# ---- World map -------------------------------------------------- #}
    <section class="mb-10">
      <h2 class="mb-3 text-[11px] font-semibold uppercase tracking-[0.18em] text-slate-500">Geographic picture</h2>
      <div id="map"></div>
      <p class="mt-2 text-[11px] text-slate-500">
        Circle size = magnitude · color = Goldstein severity (red severe → green cooperative). Markers across all
        three sourcing regions on a single global view.
      </p>
    </section>

    {# ---- What changed this week table ------------------------------- #}
    <section>
      <h2 class="mb-3 text-[11px] font-semibold uppercase tracking-[0.18em] text-slate-500">
        What changed this week · top events across all three
      </h2>
      <div class="overflow-hidden rounded-lg border neon-border bg-white">
        <table class="w-full text-[13px]">
          <thead class="border-b border-slate-200 text-left">
            <tr class="text-[10px] uppercase tracking-wider text-slate-500">
              <th class="px-3 py-2">Date</th>
              <th class="px-3 py-2">Country</th>
              <th class="px-3 py-2">Event</th>
              <th class="px-3 py-2 text-right">Sig</th>
            </tr>
          </thead>
          <tbody>
            {% for event in top_events %}
              <tr class="border-b border-slate-100 last:border-0">
                <td class="px-3 py-2 text-slate-500">{{ event.event_date }}</td>
                <td class="px-3 py-2 text-slate-500">{{ event.country }}</td>
                <td class="px-3 py-2">
                  <div class="line-clamp-2 leading-snug">{{ event.title or "—" }}</div>
                  <div class="mt-0.5 text-[10px] text-slate-400">
                    {{ event.event_family }} · {{ event.category }}
                  </div>
                </td>
                <td class="px-3 py-2 text-right font-mono text-slate-700">
                  {{ "%.2f"|format(event.significance) }}
                </td>
              </tr>
            {% else %}
              <tr><td class="px-3 py-4 text-slate-500" colspan="4">No events found.</td></tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
    </section>

    <footer class="mt-10 rounded-lg border border-slate-200 bg-white p-4 text-[12px] text-slate-600">
      <strong class="text-slate-900">How this demo is built:</strong> three independent country queries to
      <code class="rounded bg-slate-100 px-1.5 py-0.5">/api/v2/events</code> +
      <code class="rounded bg-slate-100 px-1.5 py-0.5">/api/v2/stories</code>, merged in Python so the dashboard
      can show per-country panels AND a unified map / table. LME aluminum overlay is a static placeholder — swap
      for a live macro_finance MCP call when wiring real data. Clone the repo at
      <a class="neon hover:underline" href="https://github.com/gdelt-cloud/demos/tree/main/bauxite-supply-chain-monitor" target="_blank">github.com/gdelt-cloud/demos</a>,
      set your <code class="rounded bg-slate-100 px-1.5 py-0.5">GDELT_API_KEY</code>, and run
      <code class="rounded bg-slate-100 px-1.5 py-0.5">uv run python -m bauxite</code>.
    </footer>
  </main>

  <script id="map-payload" type="application/json">{{ map_payload_json|safe }}</script>
  <script>
    (function () {
      var payload = JSON.parse(document.getElementById('map-payload').textContent);
      // World view centered for the three bauxite sourcing regions:
      // Guinea (~11N, -13E), Indonesia (~-2N, 118E), Australia (~-25N, 135E).
      var map = L.map('map').setView([0, 80], 2);
      L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
        attribution: '© OpenStreetMap contributors',
      }).addTo(map);

      (payload.events || []).forEach(function (event) {
        var size = event.marker_size || 10;
        var color = event.marker_color || '#94a3b8';
        var marker = L.circleMarker([event.latitude, event.longitude], {
          radius: size / 2,
          color: color,
          fillColor: color,
          fillOpacity: 0.55,
          weight: 1,
        }).addTo(map);
        var popup = '<strong style="color:' + color + '">' + (event.event_family || '') + ' · ' + (event.category || '') + '</strong>';
        popup += '<br>' + (event.title || '—');
        popup += '<br><span style="color:#64748b;font-size:11px">' + (event.event_date || '') + ' · ' + (event.country || '') + '</span>';
        marker.bindPopup(popup);
      });
    })();
  </script>
</body>
</html>
