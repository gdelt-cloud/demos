<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Red Sea Threat Watchboard · GDELT Cloud</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
  <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
  <style>
    body { font-family: -apple-system, BlinkMacSystemFont, "Inter", "SF Pro", Helvetica, Arial, sans-serif; }
    .font-display { font-family: "Inter", -apple-system, sans-serif; letter-spacing: 0.02em; }
    .neon { color: #5EAAFF; }
    .neon-bg { background-color: rgba(94, 170, 255, 0.08); }
    .neon-border { border-color: rgba(94, 170, 255, 0.22); }
    #map { height: 460px; width: 100%; border-radius: 0.5rem; }
    @media print {
      .no-print { display: none !important; }
      #map { height: 320px; }
    }
  </style>
</head>
<body class="bg-slate-50 text-slate-900">
  <main class="mx-auto max-w-6xl px-4 py-10 md:px-8">
    <header class="mb-8 border-b border-slate-200 pb-6">
      <div class="flex items-center gap-2 text-[11px] font-semibold uppercase tracking-[0.18em] neon">
        <span class="inline-block h-1.5 w-1.5 rounded-full bg-emerald-500"></span>
        Maritime Intelligence · GDELT Cloud Demo
      </div>
      <h1 class="mt-2 text-3xl font-bold tracking-tight md:text-4xl">Red Sea Threat Watchboard</h1>
      <p class="mt-2 max-w-3xl text-sm text-slate-600">
        Operating picture of Bab-el-Mandeb and the Red Sea coastline — structured events, energy infrastructure
        exposure, story clusters, and named entities. Built only on the GDELT Cloud public REST API.
      </p>
      <div class="mt-3 text-xs text-slate-500">
        Window: <strong>{{ start_date }}</strong> → <strong>{{ end_date }}</strong>
      </div>
    </header>

    <section class="mb-8 grid grid-cols-2 gap-3 md:grid-cols-4">
      <div class="rounded-lg border neon-border bg-white p-4">
        <div class="text-[10px] uppercase tracking-[0.18em] text-slate-500">Events</div>
        <div class="mt-1 text-2xl font-bold">{{ events_count }}</div>
        <div class="text-[11px] text-slate-500">across 6 countries</div>
      </div>
      <div class="rounded-lg border neon-border bg-white p-4">
        <div class="text-[10px] uppercase tracking-[0.18em] text-slate-500">Story clusters</div>
        <div class="mt-1 text-2xl font-bold">{{ stories_count }}</div>
        <div class="text-[11px] text-slate-500">≥8 articles</div>
      </div>
      <div class="rounded-lg border neon-border bg-white p-4">
        <div class="text-[10px] uppercase tracking-[0.18em] text-slate-500">Fatal incidents</div>
        <div class="mt-1 text-2xl font-bold">{{ fatal_count }}</div>
        <div class="text-[11px] text-slate-500">{{ total_fatalities }} fatalities</div>
      </div>
      <div class="rounded-lg border neon-border bg-white p-4">
        <div class="text-[10px] uppercase tracking-[0.18em] text-slate-500">Energy assets</div>
        <div class="mt-1 text-2xl font-bold">{{ assets_count }}</div>
        <div class="text-[11px] text-slate-500">in Bab-el-Mandeb bbox</div>
      </div>
    </section>

    <section class="mb-10 grid gap-6 lg:grid-cols-3">
      <div class="lg:col-span-2">
        <h2 class="mb-3 text-[11px] font-semibold uppercase tracking-[0.18em] text-slate-500">Geographic picture</h2>
        <div id="map"></div>
        <p class="mt-2 text-[11px] text-slate-500">
          Circle size = magnitude · color = Goldstein severity (red severe → green cooperative) · squares = oil/LNG
          terminals in Bab-el-Mandeb bbox.
        </p>
      </div>
      <aside>
        <div class="rounded-lg border neon-border bg-white p-4">
          <h3 class="text-[11px] font-semibold uppercase tracking-[0.18em] text-slate-500">Top named entities</h3>
          <ul class="mt-3 space-y-2 text-[13px]">
            {% for entity in entities %}
              <li class="flex items-center justify-between gap-2">
                <span class="truncate">{{ entity.name }}</span>
                <span class="shrink-0 rounded bg-slate-100 px-1.5 py-0.5 font-mono text-[10px] uppercase text-slate-500">
                  {{ entity.type }}
                </span>
              </li>
            {% else %}
              <li class="text-slate-500">No entities found.</li>
            {% endfor %}
          </ul>
        </div>
      </aside>
    </section>

    <section class="grid gap-6 lg:grid-cols-2">
      <div>
        <h2 class="mb-3 text-[11px] font-semibold uppercase tracking-[0.18em] text-slate-500">
          Top events · by significance
        </h2>
        <div class="overflow-hidden rounded-lg border neon-border bg-white">
          <table class="w-full text-[13px]">
            <thead class="border-b border-slate-200 text-left">
              <tr class="text-[10px] uppercase tracking-wider text-slate-500">
                <th class="px-3 py-2">Date · country</th>
                <th class="px-3 py-2">Event</th>
                <th class="px-3 py-2 text-right">Gold</th>
                <th class="px-3 py-2 text-right">Mag</th>
              </tr>
            </thead>
            <tbody>
              {% for event in top_events %}
                <tr class="border-b border-slate-100 last:border-0">
                  <td class="px-3 py-2 text-slate-500">
                    <div>{{ event.event_date }}</div>
                    <div class="text-[10px] text-slate-400">{{ event.country }}</div>
                  </td>
                  <td class="px-3 py-2">
                    <div class="line-clamp-2 leading-snug">{{ event.title or "—" }}</div>
                    <div class="mt-0.5 text-[10px] text-slate-400">
                      {{ event.event_family }} · {{ event.category }}
                    </div>
                  </td>
                  <td class="px-3 py-2 text-right font-mono text-slate-700">
                    {{ "%.1f"|format(event.goldstein) if event.goldstein is not none else "—" }}
                  </td>
                  <td class="px-3 py-2 text-right font-mono text-slate-700">
                    {{ "%.1f"|format(event.magnitude) if event.magnitude is not none else "—" }}
                  </td>
                </tr>
              {% endfor %}
            </tbody>
          </table>
        </div>
      </div>

      <div>
        <h2 class="mb-3 text-[11px] font-semibold uppercase tracking-[0.18em] text-slate-500">
          Story clusters · by article count
        </h2>
        <ul class="space-y-3">
          {% for story in top_stories %}
            <li class="rounded-lg border neon-border bg-white p-3">
              <div class="flex items-start justify-between gap-2">
                <div class="min-w-0">
                  <div class="text-[13px] font-medium leading-snug">{{ story.label }}</div>
                  <div class="mt-1 text-[11px] text-slate-500">
                    {{ story.cluster_date }} · {{ story.article_count }} articles
                  </div>
                </div>
                <span class="shrink-0 rounded neon-bg px-1.5 py-0.5 font-mono text-[10px] uppercase neon">
                  sig {{ "%.2f"|format(story.significance) }}
                </span>
              </div>
            </li>
          {% endfor %}
        </ul>
      </div>
    </section>

    <footer class="mt-10 rounded-lg border border-slate-200 bg-white p-4 text-[12px] text-slate-600">
      <strong class="text-slate-900">How this demo is built:</strong> every panel above is rendered from the
      GDELT Cloud public REST API (events, stories, entities, energy assets), no proprietary data sources.
      Clone the repo at
      <a class="neon hover:underline" href="https://github.com/gdelt-cloud/demos/tree/main/red-sea-watchboard" target="_blank">github.com/gdelt-cloud/demos</a>,
      set your <code class="rounded bg-slate-100 px-1.5 py-0.5">GDELT_API_KEY</code>, and run
      <code class="rounded bg-slate-100 px-1.5 py-0.5">uv run python -m maritime</code>.
    </footer>
  </main>

  <script id="map-payload" type="application/json">{{ map_payload_json|safe }}</script>
  <script>
    (function () {
      var payload = JSON.parse(document.getElementById('map-payload').textContent);
      var map = L.map('map').setView([17, 44.5], 4);
      L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
        attribution: '© OpenStreetMap contributors',
      }).addTo(map);

      (payload.assets || []).forEach(function (asset) {
        var marker = L.marker([asset.latitude, asset.longitude], {
          icon: L.divIcon({
            className: '',
            html: '<div style="width:10px;height:10px;background:#16a34a;border:1px solid #064e3b;box-shadow:0 0 6px rgba(22,163,74,.55)"></div>',
          }),
        }).addTo(map);
        marker.bindPopup('<strong>' + (asset.name || 'asset') + '</strong><br>' + (asset.tracker || ''));
      });

      (payload.events || []).forEach(function (event) {
        var size = event.marker_size || 10;
        var color = event.marker_color || '#94a3b8';
        var marker = L.circleMarker([event.latitude, event.longitude], {
          radius: size / 2,
          color: color,
          fillColor: color,
          fillOpacity: 0.55,
          weight: 1,
        }).addTo(map);
        var popup = '<strong style="color:' + color + '">' + (event.event_family || '') + ' · ' + (event.category || '') + '</strong>';
        popup += '<br>' + (event.title || '—');
        popup += '<br><span style="color:#64748b;font-size:11px">' + (event.event_date || '') + ' · ' + (event.country || '') + '</span>';
        marker.bindPopup(popup);
      });
    })();
  </script>
</body>
</html>
